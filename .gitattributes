# Normalise les fins de ligne : LF dans le dépôt pour tout le texte.
* text=auto eol=lf

# Binaires : pas de conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ogg binary
*.wav binary
*.mp3 binary
*.woff binary
*.woff2 binary
*.ttf binary
public/audio/music/*.mp3 filter=lfs diff=lfs merge=lfs -text
