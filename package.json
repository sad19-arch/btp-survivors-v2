{
  "name": "btp-survivors-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BTP Carnage — reconstruction propre (Vampire-Survivors-like, monde chantier). Cœur de simulation TypeScript déterministe + rendu Phaser.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "sim": "tsx tools/sim/run.ts",
    "sim:check": "tsx tools/sim/run.ts --seeds 12 --duration 1260 --enforce",
    "perf:check": "tsx tools/perf/check.ts",
    "site:plan": "tsx tools/site-plan-ascii.ts",
    "assets:qa": "tsx tools/assets/qa.ts"
  },
  "dependencies": {
    "phaser": "^3.87.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.16.0",
    "happy-dom": "^15.11.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.17.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
